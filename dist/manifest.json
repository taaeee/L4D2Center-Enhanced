{
  "manifest_version": 3,
  "name": "L4D2 Center Enhanced",
  "version": "2.0.0",
  "description": "Mejoras visuales y utilidades para L4D2Center (AutoReady, Temas, Iconos).",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "nativeMessaging",
    "notifications"
  ],
  "host_permissions": [
    "https://l4d2center.com/play.html",
    "https://api.l4d2center.com/*",
    "https://vctxtgacwuprmivvgclw.supabase.co/*",
    "http://localhost/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.jsx-loader-D6IXWf_N.js"
      ],
      "matches": [
        "https://l4d2center.com/play.html",
        "https://l4d2center.com/play.html?join_party=*"
      ],
      "run_at": "document_end",
      "css": [
        "assets/index-CmByrlG0.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://l4d2center.com/*"
      ],
      "resources": [
        "src/interceptor.js",
        "icons/add_friend.svg",
        "icons/delete_friend.svg",
        "icons/friends.svg",
        "icons/invite_sent.svg",
        "icons/nickname_edit.svg"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://l4d2center.com/*",
        "https://l4d2center.com/*"
      ],
      "resources": [
        "assets/chunk-CacB07dV.js",
        "assets/jsx-runtime-6DojhKuT.js",
        "assets/index.jsx-XYcMN1XH.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  }
}
